# ======================================================================
# Instagram credentials
# ======================================================================
# Your Instagram login username (the account Eve will post from)
IG_USERNAME=your_instagram_username
# Your Instagram password
IG_PASSWORD=your_instagram_password
# Optional: paste a sessionid cookie value from an already-logged-in
# browser/app session to import it instead of logging in with
# username/password. Leave empty to log in normally.
IG_SESSIONID=

# ======================================================================
# Gemini API key pool (text generation)
# Supports 1 to 5 keys for round-robin / failover; empty slots ignored.
# ======================================================================
GEMINI_API_KEY_1=your_gemini_api_key_1
GEMINI_API_KEY_2=your_gemini_api_key_2
GEMINI_API_KEY_3=your_gemini_api_key_3
GEMINI_API_KEY_4=your_gemini_api_key_4
GEMINI_API_KEY_5=your_gemini_api_key_5
# Legacy single-key fallback (added to the pool if not already present)
GEMINI_API_KEY=your_gemini_api_key
# Text model used by the key pool
GEMINI_MODEL=gemini-2.5-flash

# ======================================================================
# Target group chat
# ======================================================================
# Instagram thread id of the group chat Eve should participate in.
# Run `python list_threads.py` to print your threads and their ids.
TARGET_THREAD_ID=your_target_group_thread_id

# ======================================================================
# Polling / timing
# ======================================================================
# Seconds between HTTP polls when the realtime MQTT stream is down
POLL_INTERVAL_SECONDS=5
# Burst coalescing window in milliseconds (groups rapid-fire messages)
BURST_WINDOW_MS=600

# ======================================================================
# Memory extraction
# ======================================================================
# Number of messages processed per memory-extraction batch
MEMORY_BATCH_SIZE=15
# Seconds the memory worker waits between polls
MEMORY_WORKER_POLL_SECONDS=30

# ======================================================================
# Conversation context windows
# ======================================================================
# Messages per lane included in the Gemini context
CONTEXT_LANE_SIZE=15
# Raw group-chat scene window for social targeting
SOCIAL_SCENE_SIZE=15

# ======================================================================
# Social fatigue thresholds (rate-limit Eve's replies)
# ======================================================================
# Max replies allowed within a rolling 60-second window
FATIGUE_MAX_REPLIES_60S=4
# Max replies allowed within a rolling 5-minute window
FATIGUE_MAX_REPLIES_5MIN=10
# Max consecutive replies before Eve backs off
FATIGUE_MAX_CONSECUTIVE=5

# ======================================================================
# Voice mode (Gemini Live native audio)
# ======================================================================
VOICE_ENABLED=true
# Target long-run fraction of replies that become voice (~3/7)
VOICE_TARGET_RATIO=0.43
# Dedicated key for voice — never uses the text round-robin pool above
GEMINI_LIVE_API_KEY=your_gemini_live_api_key
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Must be Leda, Puck, Charon, Kore, Fenrir, Aoede, Orus, or Zephyr
GEMINI_LIVE_VOICE=Leda
VOICE_TIMEOUT_SECONDS=20
VOICE_FAILURE_THRESHOLD=3
VOICE_COOLDOWN_SECONDS=300
VOICE_HISTORY_WINDOW=7
# Path to the ffmpeg executable (used to transcode voice replies).
# Provide your own binary; "ffmpeg" works if it is on your PATH.
FFMPEG_PATH=ffmpeg
